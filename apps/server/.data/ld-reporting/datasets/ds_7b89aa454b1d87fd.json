  "normRules": [
    {
      "ruleId": "NORM-01",
      "category": "Effectiveness",
      "ruleDescription": "Pass rate per course below threshold",
      "threshold": "Pass_Rate < 0.70",
      "actionIfTriggered": "Flag course for content review; notify L&D manager",
      "priority": "High"
    },
    {
      "ruleId": "NORM-02",
      "category": "Effectiveness",
      "ruleDescription": "Average score below minimum acceptable level",
      "threshold": "Avg_Score < 6.5",
      "actionIfTriggered": "Trigger course redesign review; consider re-delivery",
      "priority": "High"
    },
    {
      "ruleId": "NORM-03",
      "category": "Attendance",
      "ruleDescription": "Attendance rate per course below target",
      "threshold": "Attendance_Rate < 0.75",
      "actionIfTriggered": "Send reminder to absentees; flag to direct manager",
      "priority": "Medium"
    },
    {
      "ruleId": "NORM-04",
      "category": "Individual",
      "ruleDescription": "Trainee passes with low attendance (possible policy violation)",
      "threshold": "Score >= Pass_Threshold AND Attendance_Rate < 0.70",
      "actionIfTriggered": "Flag for L&D review; verify with manager",
      "priority": "Medium"
    },
    {
      "ruleId": "NORM-05",
      "category": "Individual",
      "ruleDescription": "Trainee score = 0 or did not submit assessment",
      "threshold": "Score = 0 OR assessment not submitted",
      "actionIfTriggered": "Mark as Incomplete; recommend re-enrollment in next cohort",
      "priority": "High"
    },
    {
      "ruleId": "NORM-06",
      "category": "Individual",
      "ruleDescription": "Outstanding trainee highlight",
      "threshold": "Score >= 9.0 AND Attendance_Rate = 1.0",
      "actionIfTriggered": "Add to \"Star Learner\" report section; recommend for mentorship role",
      "priority": "Low"
    },
    {
      "ruleId": "NORM-07",
      "category": "Individual",
      "ruleDescription": "At-risk trainee — needs support",
      "threshold": "Score < Pass_Threshold AND Attendance_Rate >= 0.70",
      "actionIfTriggered": "Flag for 1:1 coaching; assign buddy or additional practice resource",
      "priority": "High"
    },
    {
      "ruleId": "NORM-08",
      "category": "Trainer",
      "ruleDescription": "Trainer rating below acceptable standard",
      "threshold": "Trainer_Rating_Avg < 3.5",
      "actionIfTriggered": "Escalate to L&D Manager; schedule trainer coaching session",
      "priority": "High"
    },
    {
      "ruleId": "NORM-09",
      "category": "ROI",
      "ruleDescription": "Low completion rate despite high cost",
      "threshold": "Completion_Rate < 0.80 AND Total_Cost_Scaled > 8.0",
      "actionIfTriggered": "Review course necessity; consider split delivery or self-paced format",
      "priority": "Medium"
    },
    {
      "ruleId": "NORM-10",
      "category": "ROI",
      "ruleDescription": "Negative or zero post-training performance delta",
      "threshold": "Post_Training_Perf_Delta <= 0",
      "actionIfTriggered": "Audit course design and on-the-job application support",
      "priority": "High"
    },
    {
      "ruleId": "NORM-11",
      "category": "Reporting",
      "ruleDescription": "Course with missing data cannot be reported",
      "threshold": "Any required field is NULL for Completed course status",
      "actionIfTriggered": "Block course from effectiveness report; flag as data incomplete",
      "priority": "High"
    },
    {
      "ruleId": "NORM-12",
      "category": "Attendance",
      "ruleDescription": "Trainee marked Late treated as partial attendance",
      "threshold": "Attendance_Status = Late",
      "actionIfTriggered": "Count as 0.5 session for attendance rate calculation",
      "priority": "Low"
    },
    {
      "ruleId": "NORM-13",
      "category": "Effectiveness",
      "ruleDescription": "Course completion rate calculation basis",
      "threshold": "Completion defined as >= 70% sessions attended",
      "actionIfTriggered": "Apply consistently across all courses; document in report footnote",
      "priority": "Medium"
    },
    {
      "ruleId": "NORM-14",
      "category": "Feedback",
      "ruleDescription": "Minimum feedback response rate for valid analysis",
      "threshold": "Feedback_Response_Rate < 0.60",
      "actionIfTriggered": "Mark feedback analysis as statistically insufficient; note in report",
      "priority": "Medium"
    },
    {
      "ruleId": "NORM-15",
      "category": "Individual",
      "ruleDescription": "Score inconsistency detection",
      "threshold": "Pass_Status = True AND Score < Pass_Threshold, OR Pass_Status = False AND Score >= Pass_Threshold",
      "actionIfTriggered": "Flag as data integrity issue; verify with trainer before report generation",
      "priority": "High"
    }
